  <sharedRules>
    <rule name="Suppression (X)" id="e377-b8fd-8965-88b1" hidden="false">
      <description>Add X to all enemy Suppression Tests.</description>
    </rule>
    <rule name="Blast" id="8a02-771a-659e-d0f3" hidden="false">
      <description>Ignore Terrain when determining Firepower Rating.</description>
    </rule>
    <rule name="Cooldown" id="f62b-e162-b4fc-7ef0" hidden="false">
      <description>May only fire once per Game Turn.</description>
    </rule>
    <rule name="Lock On" id="2a64-8fcf-d2f1-f689" hidden="false">
      <description>Gain +1 Firepower Rating when firing at Long Range.</description>
    </rule>
    <rule name="Devastating (FLY)" id="a0fc-d168-257d-d6eb" hidden="false">
      <description>Gain +1 Firepower Rating shooting at Flying Elements.</description>
    </rule>
    <rule name="Move or Fire" id="6593-a21b-2c12-b43c" hidden="false">
      <description>Element gains a Cooldown Token when it moves.</description>
    </rule>
    <rule name="Limited Range" id="3b90-5b6b-7745-8d94" hidden="false">
      <description>All Long Range attacks are counted as firing into Cover that is 2 Levels higher when determining Firepower Rating.</description>
    </rule>
    <rule name="Point Blank" id="f663-466c-d0cf-6652" hidden="false">
      <description>Gain +1 Firepower Rating shooting at Short Range.</description>
    </rule>
    <rule name="Active Overwatch" id="42e8-f373-e1ef-da14" hidden="false">
      <description>Re-roll failed Reaction Fire Dice. Second result must be accepted.</description>
    </rule>
    <rule name="Commanding Presence (12&quot;)" id="ecac-9a86-b929-4466" hidden="false">
      <description>Increase all friendly Reaction Fire Tests within 12&quot; by 1. Reduce all friendly Suppression Tests within 12&quot; by 1.</description>
    </rule>
    <rule name="Heroic Save (5+)" id="ffc8-e403-7311-4d8b" hidden="false">
      <description>Ignore Damage on a roll of 5 or more.</description>
    </rule>
    <rule name="Heroic Save (3+)" id="1669-a5b8-3f86-7326" hidden="false">
      <description>Ignore Damage on a roll of 3 or more.</description>
    </rule>
    <rule name="Battle Hardened (1)" id="fb0f-edeb-4ecf-3315" hidden="false">
      <description>Re-roll up to 1 failed Melee Attack Dice.</description>
    </rule>
    <rule name="Attachment (INF)" id="7f8a-e527-bd71-af6f" hidden="false">
      <description>This Element may attach to Infantry Units in the same Force, and may be deployed attached to those Units in the same Battle Group.</description>
    </rule>
    <rule name="Communications Specialist" id="f396-9aca-a891-aa39" hidden="false">
      <description>Once per Game Turn, increase the result of a Reaction Fire Test by +2 when within the Commanding Presence Range.</description>
    </rule>
    <rule name="Crash Training" id="51e3-366f-2474-df4d" hidden="false">
      <description>If a transport vehicle is destroyed while this unit is embarked inside, or an Air Support Flyer is destroyed before disembarking this Unit during a Combat Drop Mission, this unit suffers no damage and is deployed as though they disembarked from a transport.</description>
    </rule>
    <rule name="Requisite Tank Commander" id="158e-8e5b-ecc5-64b9" hidden="false">
      <description>The Requisite Tank acts as a Battle Group’s Commander and gains +1 to its React stat, and the Commanding Presence (8&quot;) Loadout for free.</description>
    </rule>
  </sharedRules>
  <sharedProfiles>
    <profile name="Frag Grenades" typeId="6c7a-4fe3-9ca0-168a" typeName="Unit Weapons" hidden="false" id="9382-8533-cc84-2df0">
      <characteristics>
        <characteristic name="Range" typeId="b105-0b2d-c20d-2f77">10”/-</characteristic>
        <characteristic name="Arc" typeId="dc58-10d6-a1f0-3f09">ALL</characteristic>
        <characteristic name="AP" typeId="b639-e494-578f-979d">3</characteristic>
