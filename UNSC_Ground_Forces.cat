<catalogue xmlns="http://www.battlescribe.net/schema/catalogueSchema" library="false" id="5744-UNSC-c952" name="UNSC_Ground_Forces" gameSystemId="sys-6399-a82f-f411-a347" gameSystemRevision="1" revision="1" battleScribeVersion="2.03" type="catalogue"><selectionEntries><selectionEntry type="unit" import="true" name="LIEUTENANT COLONEL - GENERIC COMMANDER" hidden="false" id="2e55-c546-5d35-e7a8"><categoryLinks><categoryLink targetId="1d19-aba0-3ac5-ad1e" id="3d06-5a22-5d36-a0bd" primary="true" name="1. Force Commander" /></categoryLinks><costs><cost name="pts" typeId="points" value="0" /><cost name="BR" typeId="Build Rating" value="0" /><cost name="CHA" typeId="Character" value="0" /><cost name="INF BR" typeId="7ada-7046-0588-6b62" value="0" /><cost name="ARM BR" typeId="8bde-fb02-2c4d-15ad" value="0" /><cost name="FLY BR" typeId="ec76-a9ce-7551-737e" value="0" /></costs><profiles><profile name="Lieutenant Colonel - Generic Commander" typeId="d1111111-1111-1111-1111-111111111111" typeName="Force Commander" hidden="false" id="64bc-f3b9-74bf-93d8"><characteristics><characteristic name="Total Order Dice" typeId="d111-0003-111--111-">3</characteristic><characteristic name="Order Dice Squares" typeId="d111-0004-111--111-">3</characteristic><characteristic name="General Order Dice Squares" typeId="d111-0005-111--111-">0</characteristic></characteristics></profile><profile name="Mark Your Target:" typeId="d2222222-2222-2222-2222-222222222222" typeName="Commander Order" hidden="false" id="ec39-2800-6bdc-d13a"><characteristics><characteristic name="Required Icon" typeId="51d8-d512-a091-79d7">Attack</characteristic><characteristic name="Effect" typeId="d222-0003-222--222-">Once this Order has been issued the UNSC player may add 2 additional Halo Dice to their Attack Dice Pool (including Melee).
This Order must be issued prior to any Attack being made.</characteristic></characteristics></profile><profile name="Take Cover:" typeId="d2222222-2222-2222-2222-222222222222" typeName="Commander Order" hidden="false" id="53aa-b781-bce8-e3ca"><characteristics><characteristic name="Required Icon" typeId="51d8-d512-a091-79d7">Defence</characteristic><characteristic name="Effect" typeId="d222-0003-222--222-">Once this Order has been issued the player may improve the Cover Level of a target Infantry Unit by 1 Level, up to a maximum of Heavy Cover. In the case of Armoured or Flying Vehicles improve a Unit’s Soak statistic by 2. This Order must be issued prior to an enemy’s Firing Action taking place.</characteristic></characteristics></profile><profile name="Stay Sharp:" typeId="d2222222-2222-2222-2222-222222222222" typeName="Commander Order" hidden="false" id="af2e-e1de-a2db-f637"><characteristics><characteristic name="Required Icon" typeId="51d8-d512-a091-79d7">Command</characteristic><characteristic name="Effect" typeId="d222-0003-222--222-">Once this Order has been issued the player may add 2 to a Unit’s Reaction Fire result. This Order must be issued prior to any Reaction Fire Test being made.</characteristic></characteristics></profile><profile name="Not One Step Back!:" typeId="d18e-1b18-bf35-2845" typeName="Commander Unique Ability" hidden="false" id="6656-ddb4-8bbb-ed18"><characteristics><characteristic name="Required Icon" typeId="c6f2-52f3-ee6a-60c1">2 Command</characteristic><characteristic name="Effect" typeId="ff85-a3b4-b61b-9ed2">Once per Game Turn, a UNSC Force Commander can select one UNSC Infantry Unit to remove an Activation Token. That Unit can then be selected to Activate or React later during the game turn. This Order must be issued during a UNSC Player’s Unit Activation.</characteristic></characteristics></profile></profiles></selectionEntry><selectionEntry type="unit" import="true" name="UNSC Standard Armoured Battlegroup" hidden="false" id="190c-c542-d6a9-c655"><categoryLinks><categoryLink targetId="2622-52fa-29f7-96bb" id="8311-882e-fcdc-c9c1" primary="true" name="2. Standard Battle Groups" /></categoryLinks><infoLinks><infoLink name="Standard Armoured Battlegroup Summary" id="i-bgarm-sum" hidden="false" type="profile" targetId="4bbf-0ab4-a111-c290" /><infoLink name="Requisite Tank Commander" id="i-bgarm-rule" hidden="false" type="rule" targetId="f4c6-2c9b-a8d4-f61c" /></infoLinks></selectionEntry><selectionEntry type="unit" import="true" name="UNSC Mechanised Infantry Battlegroup" hidden="false" id="2db3-8915-2519-f394"><categoryLinks><categoryLink name="2. Standard Battle Groups" hidden="false" id="433e-3417-0609-59d9" targetId="2622-52fa-29f7-96bb" primary="true" /></categoryLinks><infoLinks><infoLink name="Mechanised Infantry Battlegroup Summary" id="i-bgmech-sum" hidden="false" type="profile" targetId="7ffa-0db5-9df1-c290" /></infoLinks><selectionEntries><selectionEntry type="unit" import="true" name="1. Required" hidden="false" id="be72-7e28-42f6-b93c" collective="false"><selectionEntryGroups><selectionEntryGroup name="1.1 Required Command Unit" id="93aa-90bc-3a8e-a146" hidden="false" collective="false"><constraints><constraint type="max" value="1" field="selections" scope="parent" shared="false" id="93aa-90bc-3a8e-a146-max" percentValue="false" includeChildSelections="false" includeChildForces="false" /><constraint type="min" value="1" field="selections" scope="parent" shared="false" id="93aa-90bc-3a8e-a146-min" percentValue="false" includeChildSelections="false" includeChildForces="false" /></constraints><entryLinks><entryLink import="true" name="Officer - UNSC Army Command Unit" hidden="false" id="074e-8d96-f012-b827" targetId="bf34-cfad-df84-45c0" type="selectionEntry" /></entryLinks></selectionEntryGroup><selectionEntryGroup name="1.2 Required Infantry Unit" id="ea0d-151f-03de-b261" hidden="false" collective="false"><constraints><constraint type="max" value="1" field="selections" scope="parent" 