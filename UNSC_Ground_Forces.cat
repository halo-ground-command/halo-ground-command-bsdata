Links><infoLink name="Rocket Launchers" id="fs-2rl-link" hidden="false" type="profile" targetId="d667-63b4-52eb-2f62" /></infoLinks></selectionEntry><selectionEntry type="upgrade" import="true" name="2 Heavy Machine Guns" hidden="false" id="fs-2hmg"><costs><cost name="pts" typeId="points" value="0" /><cost name="BR" typeId="Build Rating" value="0" /><cost name="CHA" typeId="Character" value="0" /><cost name="INF BR" typeId="7ada-7046-0588-6b62" value="0" /><cost name="ARM BR" typeId="8bde-fb02-2c4d-15ad" value="0" /><cost name="FLY BR" typeId="ec76-a9ce-7551-737e" value="0" /></costs><infoLinks><infoLink name="Heavy Machine Gun" id="fs-2hmg-link" hidden="false" type="profile" targetId="5ea6-31f9-51f8-0f2c" /></infoLinks></selectionEntry></selectionEntries></selectionEntryGroup><selectionEntryGroup name="Team Leader Upgrade" id="fs-upg-leader" hidden="false" collective="false"><constraints><constraint type="min" value="0" field="selections" scope="parent" shared="false" id="fs-upg-leader-min" percentValue="false" includeChildSelections="false" includeChildForces="false" /><constraint type="max" value="1" field="selections" scope="parent" shared="false" id="fs-upg-leader-max" percentValue="false" includeChildSelections="false" includeChildForces="false" /></constraints><entryLinks><entryLink import="true" name="Army Corporal" hidden="false" id="fs-corp-link" targetId="1bb1-2a63-8f74-c0aa" type="selectionEntry" /></entryLinks></selectionEntryGroup></selectionEntryGroups></selectionEntry><selectionEntry type="unit" import="true" name="Army Corporal" hidden="false" id="1bb1-2a63-8f74-c0aa"><categoryLinks><categoryLink targetId="870a-81aa-e07c-3d01" id="corp-inf" primary="true" name="5. Infantry Units" /></categoryLinks><costs><cost name="pts" typeId="points" value="10" /><cost name="BR" typeId="Build Rating" value="0" /><cost name="CHA" typeId="Character" value="0" /><cost name="INF BR" typeId="7ada-7046-0588-6b62" value="0" /><cost name="ARM BR" typeId="8bde-fb02-2c4d-15ad" value="0" /><cost name="FLY BR" typeId="ec76-a9ce-7551-737e" value="0" /></costs><infoLinks><infoLink name="Corporal - UNSC Army Riflemen Team Leader" id="corp-prof" hidden="false" type="profile" targetId="d2bf-7a91-7810-36a2" /><infoLink name="Small Arms" id="corp-sa" hidden="false" type="profile" targetId="c7a1-541e-88b0-c0de" /><infoLink name="Frag Grenades" id="corp-fg" hidden="false" type="profile" targetId="5b5c-4386-c766-88ea" /><infoLink name="Heroic Save (5+)" id="corp-r1" hidden="false" type="rule" targetId="ffc8-e403-7311-4d8b" /></infoLinks></selectionEntry></sharedSelectionEntries><sharedRules><rule name="Suppression (X)" id="e377-b8fd-8965-88b1" hidden="false"><description>Add X to all enemy Suppression Tests.</description></rule><rule name="Blast" id="8a02-771a-659e-d0f3" hidden="false"><description>Ignore Terrain when determining Firepower Rating.</description></rule><rule name="Cooldown" id="f62b-e162-b4fc-7ef0" hidden="false"><description>May only fire once per Game Turn.</description></rule><rule name="Lock On" id="2a64-8fcf-d2f1-f689" hidden="false"><description>Gain +1 Firepower Rating when firing at Long Range.</description></rule><rule name="Devastating (FLY)" id="a0fc-d168-257d-d6eb" hidden="false"><description>Gain +1 Firepower Rating shooting at Flying Elements.</description></rule><rule name="Move or Fire" id="6593-a21b-2c12-b43c" hidden="false"><description>Element gains a Cooldown Token when it moves.</description></rule><rule name="Limited Range" id="3b90-5b6b-7745-8d94" hidden="false"><description>All Long Range attacks are counted as firing into Cover that is 2 Levels higher when determining Firepower Rating.</description></rule><rule name="Point Blank" id="f663-466c-d0cf-6652" hidden="false"><description>Gain +1 Firepower Rating shooting at Short Range.</description></rule><rule name="Active Overwatch" id="42e8-f373-e1ef-da14" hidden="false"><description>Re-roll failed Reaction Fire Dice. Second result must be accepted.</description></rule><rule name="Commanding Presence (12&quot;)" id="ecac-9a86-b929-4466" hidden="false"><description>Increase all friendly Reaction Fire Tests within 12" by 1. Reduce all friendly Suppression Tests within 12" by 1.</description></rule><rule name="Heroic Save (5+)" id="ffc8-e403-7311-4d8b" hidden="false"><description>Ignore Damage on a roll of 5 or more.</description></rule><rule name="Heroic Save (3+)" id="1669-a5b8-3f86-7326" hidden="false"><description>Ignore Damage on a roll of 3 or more.</description></rule><rule name="Battle Hardened (1)" id="fb0f-edeb-4ecf-3315" hidden="false"><description>Re-roll up to 1 failed Melee Attack Dice.</description></rule><rule name="Attachment (INF)" id="f921-31dd-0bda-f2aa" hidden="false"><description>This Element may attach to Infantry Units in the same Force, and may be deployed attached to those Units in the same Battle Group.</description></rule><rule name="Communications Specialist" id="469c-f01b-e0a3-cc38" hidden="false"><description>Once per Game Turn, increase the result of a Reaction Fire Test by +2 when within the Commanding Presence Range.</description></rule><rule name="Crash Training" id="b3b1-6ec1-0d49-92bd" hidden="false"><description>If a transport vehicle is destroyed while this unit is embarked inside, or an Air Support Flyer is destroyed before disembarking this Unit during a Combat Drop Mission, this unit suffers no damage and is deployed as though they disembarked from a transport.</description></rule><rule name="Requisite Tank Commander" id="f4c6-2c9b-a8d4-f61c" hidden="false"><description>The Requisite Tank acts as a Battle Group’s Commander and gains +1 to its React stat, and the Commanding Presence (8") Loadout for free.</description></rule></sharedRules><sharedProfiles><profile name="Mechanised Infantry Battlegroup Summary" typeId="d3333333-3333-3333-3333-333333333333" typeName="Battle Group Summary" hidden="false" id="7ffa-0db5-9df1-c290"><characteristics><characteristic name="Optional Infantry"